# Keep credentials in Electron's main process. Never expose the token through Vite.
DATAHUB_GMS_URL=http://localhost:8080
DATAHUB_GMS_TOKEN=replace-with-a-scoped-service-account-token

# Option A — DataHub Cloud / remote Streamable HTTP MCP (PAT auth).
# DATAHUB_MCP_URL=https://your-tenant.acryl.io/integrations/ai/mcp/
# DATAHUB_MCP_TOKEN=replace-with-a-scoped-service-account-token

# Option B — DataHub Core / local MCP over stdio. When DATAHUB_MCP_URL is absent,
# Electron launches the official server below using the GMS values above.
DATAHUB_MCP_COMMAND=uvx
DATAHUB_MCP_PACKAGE=mcp-server-datahub@latest

# Optional cache TTLs by evidence type (milliseconds, clamped from 5s to 1h).
DATAHUB_CACHE_ENTITY_TTL_MS=300000
DATAHUB_CACHE_SCHEMA_TTL_MS=120000
DATAHUB_CACHE_LINEAGE_TTL_MS=90000
