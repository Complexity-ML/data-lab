{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DATA LAB Setup",
  "version": "0.1.0",
  "identifier": "ai.labo.data.setup",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "DATA LAB Setup",
        "width": 720,
        "height": 650,
        "minWidth": 620,
        "minHeight": 570,
        "resizable": true,
        "center": true,
        "visible": false,
        "backgroundColor": "#111827"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "nsis"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Install and update DATA LAB from source",
    "longDescription": "A source-first bootstrap installer that fetches the latest DATA LAB release and builds it locally.",
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-",
      "minimumSystemVersion": "12.0",
      "dmg": {
        "windowSize": {
          "width": 560,
          "height": 320
        },
        "appPosition": {
          "x": 145,
          "y": 155
        },
        "applicationFolderPosition": {
          "x": 415,
          "y": 155
        }
      }
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    }
  }
}
